PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ecosphere

# AI and search providers
GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key

# Signed guest sessions
SESSION_SECRET=replace_with_a_long_random_secret

# Optional Clerk accounts. Leave both blank to keep guest-only mode.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Basic-auth credentials for /admin.html and /api/admin/history
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
